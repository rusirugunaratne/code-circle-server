							"raw": "{\n    \"title\": \"Example Snippet\",\n    \"description\": \"A test snippet showing async functionality\",\n    \"code\": \"async function fetchData() {\\n  const response = await fetch('https://api.example.com');\\n  return response.json();\\n}\",\n    \"language\": \"javascript\",\n    \"tags\": [\"test\", \"node\", \"async\"]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/snippets",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"snippets"
							]
						}
					},
					"response": []
